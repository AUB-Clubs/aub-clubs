# -----------------------------------------------------------------------------
# AUB Clubs root environment example
# Copy this file to .env for local development and replace placeholder values.
# Do not commit real secrets.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aub_clubs"

# Optional direct connection URL for Prisma migrations. If omitted, Prisma uses
# DATABASE_URL from prisma.config.ts.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/aub_clubs"

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
UNIVERSITY_TIMEZONE="Asia/Beirut"

# Comma-separated emails allowed to access university admin dashboards.
UNIVERSITY_ADMIN_EMAILS="admin@aub.edu.lb"

# -----------------------------------------------------------------------------
# Supabase Auth and Storage
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_API_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-or-anon-key"

# Server-side upload key. Prefer SUPABASE_SERVICE_ROLE_KEY. The code also accepts
# SUPABASE_SECRET_KEY, SUPABASE_SERVICE_KEY, or SUPABASE_SERVICE_ROLE.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Optional aliases supported by src/lib/supabase-storage.ts. Leave commented
# unless your Supabase project uses these names in deployment.
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# SUPABASE_SECRET_KEY="your-supabase-service-role-key"
# SUPABASE_SERVICE_KEY="your-supabase-service-role-key"
# SUPABASE_SERVICE_ROLE="your-supabase-service-role-key"

# -----------------------------------------------------------------------------
# OpenAI Features
# Used by chatbot, schedule inference, RAG hydration, and event generation.
# -----------------------------------------------------------------------------
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-5.4"

# -----------------------------------------------------------------------------
# Google GenAI
# Used by the event generator for generated post/event images.
# -----------------------------------------------------------------------------
GOOGLE_API_KEY="your-google-api-key"
EVENT_IMAGES_SUPABASE_BUCKET="uploads"

# -----------------------------------------------------------------------------
# Microsoft Calendar Integration
# Required only if Outlook calendar linking is enabled.
# -----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID="your-azure-application-client-id"
MICROSOFT_CLIENT_SECRET="your-azure-application-client-secret"
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/integrations/microsoft/callback"
MICROSOFT_TENANT="common"

# Encryption key for stored Microsoft refresh tokens. Must be 32 bytes when
# decoded/interpreted by src/modules/calendar/server/token-crypto.ts.
CALENDAR_TOKEN_ENCRYPTION_KEY="replace-with-a-32-byte-secret"

# Optional legacy alias accepted by the calendar token crypto helper.
# TOKEN_ENCRYPTION_KEY="replace-with-a-32-byte-secret"

# -----------------------------------------------------------------------------
# Moderation Inference Service
# Required only when content moderation endpoints are used.
# -----------------------------------------------------------------------------
INFERENCE_URL="http://localhost:8080"
MODERATION_TIMEOUT_MS="120000"
MODERATION_RETRIES="3"

# -----------------------------------------------------------------------------
# MCP Chatbot Tools
# Required only when chatbot tool-calling through the MCP server is enabled.
# The mcp-server package has its own .env.example as well.
# -----------------------------------------------------------------------------
MCP_SERVER_URL="http://localhost:8081/mcp"
MCP_BEARER_TOKEN="replace-me-with-a-long-random-secret"

# -----------------------------------------------------------------------------
# Playwright / E2E Test Bypass
# Playwright sets E2E_TEST_MODE=true automatically in its webServer config.
# Keep these values aligned with prisma/seed.ts and e2e/fixtures.ts.
# -----------------------------------------------------------------------------
PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
E2E_TEST_MODE="false"
E2E_AUTH_SECRET="local-e2e-secret"
E2E_AUTH_USER_ID="00000000-0000-4000-8000-000000000001"

# -----------------------------------------------------------------------------
# Operations Scripts
# Used by operations/sync_gsm_env.js when syncing env from Google Secret Manager.
# -----------------------------------------------------------------------------
# ENV_FILE=".env"
# GCP_PROJECT_ID="your-gcp-project-id"
# SECRET_ID="your-secret-manager-secret-id"

# -----------------------------------------------------------------------------
# CI
# -----------------------------------------------------------------------------
# CI="true"
